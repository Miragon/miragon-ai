{
  "name": "@miragon-ai/client-cibseven",
  "version": "0.1.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Miragon/miragon-ai.git",
    "directory": "packages/client-cibseven"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "restricted"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./schemas": {
      "types": "./dist/schemas/index.d.ts",
      "import": "./dist/schemas/index.js"
    },
    "./widgets": {
      "types": "./dist/widgets.d.ts",
      "import": "./dist/widgets.js"
    },
    "./*": {
      "types": "./dist/*.d.ts",
      "import": "./dist/*.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "generate": "openapi-ts"
  },
  "dependencies": {
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@hey-api/openapi-ts": "0.94.5",
    "typescript": "5.9.3",
    "vitest": "4.1.4"
  }
}
