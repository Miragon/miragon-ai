# Local-dev configuration — copy to `.env` and adjust.
#
# Loaded by `pnpm dev` via dotenv-cli (`dotenv -e .env`): plain KEY=VALUE
# lines, no `export`, no quotes around inline-JSON values. `pnpm dev` runs
# without a `.env`, but analytics then default to the wrong Prometheus port
# (see PROMETHEUS_URL below).

# ── Camunda 7 / CIB Seven engine (read by packages/mcp-camunda7/src/module.ts) ──
CAMUNDA_BASE_URL=http://localhost:8410/engine-rest
# basic | bearer | passthrough | none — passthrough forwards each MCP caller's
# bearer token to the engine per request (no static credentials; requires an
# engine with REST authentication enabled, a default engine ignores the token).
# basic requires USERNAME+PASSWORD, bearer requires TOKEN — enforced at boot.
CAMUNDA_AUTH_TYPE=basic
CAMUNDA_USERNAME=demo
CAMUNDA_PASSWORD=demo
# CAMUNDA_TOKEN=...                      # only for CAMUNDA_AUTH_TYPE=bearer

# Multi-engine (overrides CAMUNDA_BASE_URL). The second engine on :8411 only
# runs under `docker compose --profile multi-engine up -d`. Each entry may
# carry its own `auth` ({type, username?, password?, token?}); entries without
# one fall back to the global CAMUNDA_* settings above.
# Optional per engine: "flavor" ("cibseven" | "operaton" | "camunda7", default "cibseven") selects
# the vendor's cockpit-link routes — mixed fleets in one server are supported.
# CAMUNDA_ENGINES_JSON=[{"id":"prod-a","baseUrl":"http://localhost:8410/engine-rest"},{"id":"prod-b","baseUrl":"http://localhost:8411/engine-rest","flavor":"operaton","auth":{"type":"basic","username":"demo","password":"demo"}}]

# ── Prometheus (analytics data source) ────────────────────────────────────
# The Compose stack publishes Prometheus on host port 8460. Unset → defaults
# to http://localhost:9090 (the bare Prometheus port), which does NOT match
# the stack and makes every analytics query 404 (the server warns at boot).
PROMETHEUS_URL=http://localhost:8460

# ── MCP_OAUTH — optional OAuth resource server ─────────────────────────────
# Validates bearer tokens on /mcp against your IdP (requests without a valid
# token get 401) and serves the .well-known discovery metadata. Only the MCP
# endpoint is protected — widget assets and the dev inspector are not.
# Combine with CAMUNDA_AUTH_TYPE=passthrough to forward the validated token
# to the engine. Exactly one of the four providers:
# MCP_OAUTH={"provider":"keycloak","serverUrl":"https://kc.example.com","realm":"platform","audience":"https://mcp.example.com/mcp"}
# MCP_OAUTH={"provider":"auth0","domain":"tenant.eu.auth0.com","audience":"https://mcp.example.com/mcp"}
# MCP_OAUTH={"provider":"oidc","issuer":"https://idp.example.com","jwksUrl":"https://idp.example.com/jwks","authEndpoint":"https://idp.example.com/authorize","tokenEndpoint":"https://idp.example.com/token","audience":"https://mcp.example.com/mcp"}
# oidc-proxy: IdP WITHOUT Dynamic Client Registration — a pre-registered
#   client. The server hands MCP clients the fixed clientId and injects the
#   secret at token exchange (clients never see it). REQUIRES MCP_URL set to
#   the public base URL, <MCP_URL>/oauth/callback registered as a redirect URI
#   at the IdP, and `allowedRedirectUris` listing the exact MCP-client callback
#   URLs (this allowlist is the safeguard — without it mcp-use's proxy would
#   forward the auth code to any redirect_uri). `clientSecret` may instead be a
#   `clientSecretEnvVar` naming another env var; omit both for a public client.
# MCP_OAUTH={"provider":"oidc-proxy","issuer":"https://idp.example.com","jwksUrl":"https://idp.example.com/jwks","authEndpoint":"https://idp.example.com/authorize","tokenEndpoint":"https://idp.example.com/token","clientId":"mcp-server-camunda7","clientSecret":"...","allowedRedirectUris":["https://claude.ai/api/mcp/auth_callback"],"audience":"https://mcp.example.com/mcp"}

# ── Optional persistence & thresholds ──────────────────────────────────────
# Persist dashboards saved via `save-dashboard` across restarts (unset → in-memory).
# MCP_DASHBOARD_DIR=./.dashboards
# Persist user profiles (language, theme, engine availability + default,
# dashboard and analytics preferences) across restarts (unset → in-memory).
# MCP_PROFILE_DIR=./.profiles
# Engine-health verdict thresholds (defaults 50 / 25): "critical" at
# >= CRITICAL_INCIDENTS open incidents in total, or when a single failure
# cluster reaches >= CRITICAL_CLUSTER_SIZE incidents.
# CAMUNDA_HEALTH_CRITICAL_INCIDENTS=50
# CAMUNDA_HEALTH_CRITICAL_CLUSTER_SIZE=25
