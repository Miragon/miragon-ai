          </camunda:formField>
          <camunda:formField id="region" label="Region" type="string">
            <camunda:properties><camunda:property id="readonly" value="true" /></camunda:properties>
          </camunda:formField>
          <camunda:formField id="decision" label="Decision" type="string">
            <camunda:values>
              <camunda:value id="positive" name="positive" />
              <camunda:value id="negative" name="negative" />
            </camunda:values>
          </camunda:formField>
        </camunda:formData>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_18i81hz</bpmn:incoming>
      <bpmn:outgoing>Flow_0ax166r</bpmn:outgoing>
    </bpmn:userTask>
