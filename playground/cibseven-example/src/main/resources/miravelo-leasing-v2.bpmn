<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:camunda="http://camunda.org/schema/1.0/bpmn" xmlns:modeler="http://camunda.org/schema/modeler/1.0" id="Definitions_v2" targetNamespace="http://bpmn.io/schema/bpmn" exporter="Camunda Modeler" exporterVersion="5.41.0" modeler:executionPlatform="Camunda Platform" modeler:executionPlatformVersion="7.24.0">
  <bpmn:collaboration id="Collaboration_v2">
    <bpmn:participant id="Participant_v2" name="Miravelo - Bike Leasing (v2)" processRef="miraveloLeasing" />
  </bpmn:collaboration>
  <bpmn:process id="miraveloLeasing" isExecutable="true" camunda:historyTimeToLive="P30D">
    <bpmn:exclusiveGateway id="Gateway_Creditworthy" name="Customer creditworthy?" default="Flow_18i81hz">
      <bpmn:incoming>Flow_0vvp9qn</bpmn:incoming>
      <bpmn:outgoing>Flow_1oiz1dg</bpmn:outgoing>
      <bpmn:outgoing>Flow_18i81hz</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:userTask id="Activity_AccelerateDecision" name="Accelerate decision making">
      <bpmn:extensionElements>
        <camunda:formData>
          <camunda:formField id="customerId" label="Customer ID" type="string">
            <camunda:properties><camunda:property id="readonly" value="true" /></camunda:properties>
          </camunda:formField>
          <camunda:formField id="creditScore" label="Credit Score" type="long">
            <camunda:properties><camunda:property id="readonly" value="true" /></camunda:properties>
          </camunda:formField>
          <camunda:formField id="creditworthy" label="Creditworthy" type="boolean">
            <camunda:properties><camunda:property id="readonly" value="true" /></camunda:properties>
          </camunda:formField>
          <camunda:formField id="leaseAmount" label="Lease Amount" type="long">
            <camunda:properties><camunda:property id="readonly" value="true" /></camunda:properties>
          </camunda:formField>
          <camunda:formField id="leaseTermMonths" label="Lease Term (months)" type="long">
            <camunda:properties><camunda:property id="readonly" value="true" /></camunda:properties>
          </camunda:formField>
          <camunda:formField id="bikeModel" label="Bike Model" type="string">
            <camunda:properties><camunda:property id="readonly" value="true" /></camunda:properties>
          </camunda:formField>
          <camunda:formField id="customerSegment" label="Customer Segment" type="string">
            <camunda:properties><camunda:property id="readonly" value="true" /></camunda:properties>
          </camunda:formField>
          <camunda:formField id="channel" label="Channel" type="string">
            <camunda:properties><camunda:property id="readonly" value="true" /></camunda:properties>
          </camunda:formField>
          <camunda:formField id="region" label="Region" type="string">
            <camunda:properties><camunda:property id="readonly" value="true" /></camunda:properties>
          </camunda:formField>
        </camunda:formData>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_1py2c7t</bpmn:incoming>
      <bpmn:outgoing>Flow_0r2ryqa</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:endEvent id="Event_DecisionAccelerated" name="Decision accelerated">
      <bpmn:incoming>Flow_0r2ryqa</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:callActivity id="Activity_AssessCreditworthiness" name="Assess customer creditability" calledElement="assessCreditworthiness">
      <bpmn:extensionElements>
        <camunda:in variables="all" />
        <!-- ${600} forces JUEL to evaluate as a numeric literal so the
             delegate's `as? Number` cast succeeds. A bare "600" would be
             passed through as a String and the delegate would fall back to
             the v1 default (550). -->
        <camunda:in target="creditScoreThreshold" sourceExpression="${600}" />
        <camunda:out variables="all" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_v2_va_to_assess</bpmn:incoming>
      <bpmn:outgoing>Flow_0vvp9qn</bpmn:outgoing>
    </bpmn:callActivity>
    <bpmn:exclusiveGateway id="Gateway_Decision" name="Decision?" default="Flow_1yvzx67">
      <bpmn:incoming>Flow_0ax166r</bpmn:incoming>
      <bpmn:outgoing>Flow_0vnxels</bpmn:outgoing>
      <bpmn:outgoing>Flow_1yvzx67</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:endEvent id="Event_PolicyIssued" name="Leasing Policy issued">
      <bpmn:incoming>Flow_1cy38un</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sendTask id="Activity_SendPolicy" name="Send policy to customer" camunda:delegateExpression="${sendPolicyDelegate}" camunda:asyncBefore="true">
      <bpmn:incoming>Flow_0v4qedl</bpmn:incoming>
      <bpmn:outgoing>Flow_1cy38un</bpmn:outgoing>
    </bpmn:sendTask>
    <bpmn:serviceTask id="Activity_DeliverPolicy" name="Delivery bike leasing policy" camunda:delegateExpression="${deliverLeasingPolicyDelegate}" camunda:asyncBefore="true">
      <bpmn:incoming>Flow_1oiz1dg</bpmn:incoming>
      <bpmn:incoming>Flow_0vnxels</bpmn:incoming>
      <bpmn:outgoing>Flow_0v4qedl</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="Activity_RejectPolicy" name="Reject bike leasing policy" camunda:delegateExpression="${rejectLeasingPolicyDelegate}" camunda:asyncBefore="true">
      <bpmn:incoming>Flow_1yvzx67</bpmn:incoming>
      <bpmn:outgoing>Flow_1cc5ecu</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:endEvent id="Event_PolicyRejected" name="Leasing Policy Rejected">
      <bpmn:incoming>Flow_0m7ynmt</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sendTask id="Activity_SendRejection" name="Send rejection to customer" camunda:delegateExpression="${sendRejectionDelegate}" camunda:asyncBefore="true">
      <bpmn:incoming>Flow_1cc5ecu</bpmn:incoming>
      <bpmn:outgoing>Flow_0m7ynmt</bpmn:outgoing>
    </bpmn:sendTask>
    <bpmn:userTask id="Activity_DecideOnApplication" name="Decide on application">
      <bpmn:extensionElements>
        <camunda:formData>
          <camunda:formField id="customerId" label="Customer ID" type="string">
            <camunda:properties><camunda:property id="readonly" value="true" /></camunda:properties>
          </camunda:formField>
          <camunda:formField id="creditScore" label="Credit Score" type="long">
            <camunda:properties><camunda:property id="readonly" value="true" /></camunda:properties>
          </camunda:formField>
          <camunda:formField id="creditworthy" label="Creditworthy" type="boolean">
            <camunda:properties><camunda:property id="readonly" value="true" /></camunda:properties>
          </camunda:formField>
          <camunda:formField id="leaseAmount" label="Lease Amount" type="long">
            <camunda:properties><camunda:property id="readonly" value="true" /></camunda:properties>
          </camunda:formField>
          <camunda:formField id="leaseTermMonths" label="Lease Term (months)" type="long">
            <camunda:properties><camunda:property id="readonly" value="true" /></camunda:properties>
          </camunda:formField>
          <camunda:formField id="bikeModel" label="Bike Model" type="string">
            <camunda:properties><camunda:property id="readonly" value="true" /></camunda:properties>
          </camunda:formField>
          <camunda:formField id="customerSegment" label="Customer Segment" type="string">
            <camunda:properties><camunda:property id="readonly" value="true" /></camunda:properties>
          </camunda:formField>
          <camunda:formField id="channel" label="Channel" type="string">
            <camunda:properties><camunda:property id="readonly" value="true" /></camunda:properties>
          </camunda:formField>
          <camunda:formField id="region" label="Region" type="string">
            <camunda:properties><camunda:property id="readonly" value="true" /></camunda:properties>
          </camunda:formField>
          <camunda:formField id="decision" label="Decision" type="string">
            <camunda:values>
              <camunda:value id="positive" name="positive" />
              <camunda:value id="negative" name="negative" />
            </camunda:values>
          </camunda:formField>
        </camunda:formData>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_18i81hz</bpmn:incoming>
      <bpmn:outgoing>Flow_0ax166r</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:serviceTask id="Activity_ResolveCustomer" name="Create or resolve customer from CRM" camunda:delegateExpression="${createOrResolveCustomerDelegate}" camunda:asyncBefore="true">
      <bpmn:incoming>Flow_1fnfazk</bpmn:incoming>
      <bpmn:outgoing>Flow_v2_resolve_to_va</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="Activity_VerifyAddress" name="Verify customer address" camunda:delegateExpression="${verifyAddressDelegate}" camunda:asyncBefore="true">
      <bpmn:incoming>Flow_v2_resolve_to_va</bpmn:incoming>
      <bpmn:outgoing>Flow_v2_va_to_assess</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:startEvent id="StartEvent_LeasingInquiry" name="Leasing Inquiry received">
      <bpmn:outgoing>Flow_1fnfazk</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:boundaryEvent id="Event_DecisionTimeout" name="after 2 hours" cancelActivity="false" attachedToRef="Activity_DecideOnApplication">
      <bpmn:outgoing>Flow_1py2c7t</bpmn:outgoing>
      <bpmn:timerEventDefinition id="TimerEventDefinition_v2">
        <bpmn:timeDuration xsi:type="bpmn:tFormalExpression" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">PT2H</bpmn:timeDuration>
      </bpmn:timerEventDefinition>
    </bpmn:boundaryEvent>
    <bpmn:sequenceFlow id="Flow_0vvp9qn" sourceRef="Activity_AssessCreditworthiness" targetRef="Gateway_Creditworthy" />
    <bpmn:sequenceFlow id="Flow_1oiz1dg" name="yes" sourceRef="Gateway_Creditworthy" targetRef="Activity_DeliverPolicy">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">${creditworthy == true}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_18i81hz" name="risk identified" sourceRef="Gateway_Creditworthy" targetRef="Activity_DecideOnApplication" />
    <bpmn:sequenceFlow id="Flow_1py2c7t" sourceRef="Event_DecisionTimeout" targetRef="Activity_AccelerateDecision" />
    <bpmn:sequenceFlow id="Flow_0r2ryqa" sourceRef="Activity_AccelerateDecision" targetRef="Event_DecisionAccelerated" />
    <bpmn:sequenceFlow id="Flow_v2_resolve_to_va" sourceRef="Activity_ResolveCustomer" targetRef="Activity_VerifyAddress" />
    <bpmn:sequenceFlow id="Flow_v2_va_to_assess" sourceRef="Activity_VerifyAddress" targetRef="Activity_AssessCreditworthiness" />
    <bpmn:sequenceFlow id="Flow_0ax166r" sourceRef="Activity_DecideOnApplication" targetRef="Gateway_Decision" />
    <bpmn:sequenceFlow id="Flow_0vnxels" name="positive" sourceRef="Gateway_Decision" targetRef="Activity_DeliverPolicy">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">${decision == "positive"}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_1yvzx67" name="negative" sourceRef="Gateway_Decision" targetRef="Activity_RejectPolicy" />
    <bpmn:sequenceFlow id="Flow_1cy38un" sourceRef="Activity_SendPolicy" targetRef="Event_PolicyIssued" />
    <bpmn:sequenceFlow id="Flow_0v4qedl" sourceRef="Activity_DeliverPolicy" targetRef="Activity_SendPolicy" />
    <bpmn:sequenceFlow id="Flow_1cc5ecu" sourceRef="Activity_RejectPolicy" targetRef="Activity_SendRejection" />
    <bpmn:sequenceFlow id="Flow_0m7ynmt" sourceRef="Activity_SendRejection" targetRef="Event_PolicyRejected" />
    <bpmn:sequenceFlow id="Flow_1fnfazk" sourceRef="StartEvent_LeasingInquiry" targetRef="Activity_ResolveCustomer" />
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_v2">
    <bpmndi:BPMNPlane id="BPMNPlane_v2" bpmnElement="Collaboration_v2">
      <bpmndi:BPMNShape id="Participant_v2_di" bpmnElement="Participant_v2" isHorizontal="true">
        <dc:Bounds x="160" y="55" width="1620" height="465" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="StartEvent_LeasingInquiry_di" bpmnElement="StartEvent_LeasingInquiry">
        <dc:Bounds x="232" y="162" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Activity_ResolveCustomer_di" bpmnElement="Activity_ResolveCustomer">
        <dc:Bounds x="320" y="140" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Activity_VerifyAddress_di" bpmnElement="Activity_VerifyAddress">
        <dc:Bounds x="450" y="140" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Activity_AssessCreditworthiness_di" bpmnElement="Activity_AssessCreditworthiness">
        <dc:Bounds x="580" y="140" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_Creditworthy_di" bpmnElement="Gateway_Creditworthy" isMarkerVisible="true">
        <dc:Bounds x="710" y="155" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Activity_DecideOnApplication_di" bpmnElement="Activity_DecideOnApplication">
        <dc:Bounds x="830" y="380" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Event_DecisionTimeout_di" bpmnElement="Event_DecisionTimeout">
        <dc:Bounds x="882" y="362" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Activity_AccelerateDecision_di" bpmnElement="Activity_AccelerateDecision">
        <dc:Bounds x="940" y="260" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Event_DecisionAccelerated_di" bpmnElement="Event_DecisionAccelerated">
        <dc:Bounds x="1082" y="282" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_Decision_di" bpmnElement="Gateway_Decision" isMarkerVisible="true">
        <dc:Bounds x="1165" y="395" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Activity_DeliverPolicy_di" bpmnElement="Activity_DeliverPolicy">
        <dc:Bounds x="1290" y="140" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Activity_SendPolicy_di" bpmnElement="Activity_SendPolicy">
        <dc:Bounds x="1450" y="140" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Event_PolicyIssued_di" bpmnElement="Event_PolicyIssued">
        <dc:Bounds x="1592" y="162" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Activity_RejectPolicy_di" bpmnElement="Activity_RejectPolicy">
        <dc:Bounds x="1290" y="380" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Activity_SendRejection_di" bpmnElement="Activity_SendRejection">
        <dc:Bounds x="1450" y="380" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Event_PolicyRejected_di" bpmnElement="Event_PolicyRejected">
        <dc:Bounds x="1592" y="402" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="Flow_1fnfazk_di" bpmnElement="Flow_1fnfazk">
        <di:waypoint x="268" y="180" />
        <di:waypoint x="320" y="180" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_v2_resolve_to_va_di" bpmnElement="Flow_v2_resolve_to_va">
        <di:waypoint x="420" y="180" />
        <di:waypoint x="450" y="180" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_v2_va_to_assess_di" bpmnElement="Flow_v2_va_to_assess">
        <di:waypoint x="550" y="180" />
        <di:waypoint x="580" y="180" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_0vvp9qn_di" bpmnElement="Flow_0vvp9qn">
        <di:waypoint x="680" y="180" />
        <di:waypoint x="710" y="180" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_1oiz1dg_di" bpmnElement="Flow_1oiz1dg">
        <di:waypoint x="760" y="180" />
        <di:waypoint x="1290" y="180" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_18i81hz_di" bpmnElement="Flow_18i81hz">
        <di:waypoint x="735" y="205" />
        <di:waypoint x="735" y="420" />
        <di:waypoint x="830" y="420" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_1py2c7t_di" bpmnElement="Flow_1py2c7t">
        <di:waypoint x="900" y="362" />
        <di:waypoint x="900" y="300" />
        <di:waypoint x="940" y="300" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_0r2ryqa_di" bpmnElement="Flow_0r2ryqa">
        <di:waypoint x="1040" y="300" />
        <di:waypoint x="1082" y="300" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_0ax166r_di" bpmnElement="Flow_0ax166r">
        <di:waypoint x="930" y="420" />
        <di:waypoint x="1165" y="420" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_0vnxels_di" bpmnElement="Flow_0vnxels">
        <di:waypoint x="1190" y="395" />
        <di:waypoint x="1190" y="180" />
        <di:waypoint x="1290" y="180" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_1yvzx67_di" bpmnElement="Flow_1yvzx67">
        <di:waypoint x="1215" y="420" />
        <di:waypoint x="1290" y="420" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_1cy38un_di" bpmnElement="Flow_1cy38un">
        <di:waypoint x="1550" y="180" />
        <di:waypoint x="1592" y="180" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_0v4qedl_di" bpmnElement="Flow_0v4qedl">
        <di:waypoint x="1390" y="180" />
        <di:waypoint x="1450" y="180" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_1cc5ecu_di" bpmnElement="Flow_1cc5ecu">
        <di:waypoint x="1390" y="420" />
        <di:waypoint x="1450" y="420" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_0m7ynmt_di" bpmnElement="Flow_0m7ynmt">
        <di:waypoint x="1550" y="420" />
        <di:waypoint x="1592" y="420" />
      </bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>
