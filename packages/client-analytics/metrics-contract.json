{
  "$comment": "Single source of truth for the Kotlin<->TS metric contract. The Kotlin engine plugin (engine-plugins/cibseven-history-metrics) emits the OTEL instruments (otelName); the OTEL Collector's Prometheus exporter normalises them (dots -> underscores, unit suffix `_seconds` for unit `s`, `_total` for monotonic counters) into promName, which is what the TS queries (packages/client-analytics/src/metric-names.ts), the alert rules (playground/docker/prometheus/alerts.yml) and the Grafana dashboards (playground/docker/grafana/dashboards/*.json) consume. Histograms list the base promName; the `_sum`/`_count`/`_bucket` series are implied. `knownValues` documents label values consumers may rely on. Change a metric HERE first - contract tests on both sides (src/metrics-contract.test.ts and MetricsContractTest.kt) enforce consistency.",
  "metrics": [
    {
      "otelName": "camunda.process.instance.started",
      "promName": "camunda_process_instance_started_total",
      "type": "counter",
      "unit": "",
      "labels": ["process_definition_key", "process_definition_version", "engine_id", "tenant_id"]
    },
    {
      "otelName": "camunda.process.instance.ended",
      "promName": "camunda_process_instance_ended_total",
      "type": "counter",
      "unit": "",
      "labels": [
        "process_definition_key",
        "process_definition_version",
        "engine_id",
        "tenant_id",
        "state"
      ],
      "knownValues": {
        "state": ["COMPLETED", "EXTERNALLY_TERMINATED", "INTERNALLY_TERMINATED"]
      }
    },
    {
      "otelName": "camunda.process.instance.duration",
      "promName": "camunda_process_instance_duration_seconds",
      "type": "histogram",
      "unit": "s",
      "labels": ["process_definition_key", "process_definition_version", "engine_id", "tenant_id"]
    },
    {
      "otelName": "camunda.activity.ended",
      "promName": "camunda_activity_ended_total",
      "type": "counter",
      "unit": "",
      "labels": ["process_definition_key", "activity_id", "activity_type", "engine_id"]
    },
    {
      "otelName": "camunda.activity.duration",
      "promName": "camunda_activity_duration_seconds",
      "type": "histogram",
      "unit": "s",
      "labels": ["process_definition_key", "activity_id", "activity_type", "engine_id"]
    },
    {
      "otelName": "camunda.usertask.created",
      "promName": "camunda_usertask_created_total",
      "type": "counter",
      "unit": "",
      "labels": ["process_definition_key", "task_definition_key", "engine_id"]
    },
    {
      "otelName": "camunda.usertask.completed",
      "promName": "camunda_usertask_completed_total",
      "type": "counter",
      "unit": "",
      "labels": ["process_definition_key", "task_definition_key", "engine_id"]
    },
    {
      "otelName": "camunda.usertask.duration",
      "promName": "camunda_usertask_duration_seconds",
      "type": "histogram",
      "unit": "s",
      "labels": ["process_definition_key", "task_definition_key", "engine_id"]
    },
    {
      "otelName": "camunda.incident.created",
      "promName": "camunda_incident_created_total",
      "type": "counter",
      "unit": "",
      "labels": ["process_definition_key", "activity_id", "incident_type", "engine_id"]
    },
    {
      "otelName": "camunda.incident.resolved",
