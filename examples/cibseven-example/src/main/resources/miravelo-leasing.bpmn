      <bpmn:incoming>Flow_1py2c7t</bpmn:incoming>
      <bpmn:outgoing>Flow_0r2ryqa</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:endEvent id="Event_DecisionAccelerated" name="Decision accelerated">
      <bpmn:incoming>Flow_0r2ryqa</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:callActivity id="Activity_AssessCreditworthiness" name="Assess customer creditability" calledElement="assessCreditworthiness">
      <bpmn:extensionElements>
        <camunda:in variables="all" />
        <camunda:out variables="all" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_07uig79</bpmn:incoming>
      <bpmn:outgoing>Flow_0vvp9qn</bpmn:outgoing>
    </bpmn:callActivity>
    <bpmn:exclusiveGateway id="Gateway_Decision" name="Decision?" default="Flow_1yvzx67">
      <bpmn:incoming>Flow_0ax166r</bpmn:incoming>
      <bpmn:outgoing>Flow_0vnxels</bpmn:outgoing>
      <bpmn:outgoing>Flow_1yvzx67</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:endEvent id="Event_PolicyIssued" name="Leasing Policy issued">
      <bpmn:incoming>Flow_1cy38un</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sendTask id="Activity_SendPolicy" name="Send policy to customer" camunda:delegateExpression="${sendPolicyDelegate}" camunda:asyncBefore="true">
      <bpmn:incoming>Flow_0v4qedl</bpmn:incoming>
      <bpmn:outgoing>Flow_1cy38un</bpmn:outgoing>
    </bpmn:sendTask>
    <bpmn:serviceTask id="Activity_DeliverPolicy" name="Delivery bike leasing policy" camunda:delegateExpression="${deliverLeasingPolicyDelegate}" camunda:asyncBefore="true">
      <bpmn:incoming>Flow_1oiz1dg</bpmn:incoming>
      <bpmn:incoming>Flow_0vnxels</bpmn:incoming>
      <bpmn:outgoing>Flow_0v4qedl</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="Activity_RejectPolicy" name="Reject bike leasing policy" camunda:delegateExpression="${rejectLeasingPolicyDelegate}" camunda:asyncBefore="true">
      <bpmn:incoming>Flow_1yvzx67</bpmn:incoming>
      <bpmn:outgoing>Flow_1cc5ecu</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:endEvent id="Event_PolicyRejected" name="Leasing Policy Rejected">
      <bpmn:incoming>Flow_0m7ynmt</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sendTask id="Activity_SendRejection" name="Send rejection to customer" camunda:delegateExpression="${sendRejectionDelegate}" camunda:asyncBefore="true">
      <bpmn:incoming>Flow_1cc5ecu</bpmn:incoming>
      <bpmn:outgoing>Flow_0m7ynmt</bpmn:outgoing>
    </bpmn:sendTask>
    <bpmn:userTask id="Activity_DecideOnApplication" name="Decide on application">
      <bpmn:extensionElements>
        <camunda:formData>
          <camunda:formField id="customerId" label="Customer ID" type="string">
            <camunda:properties><camunda:property id="readonly" value="true" /></camunda:properties>
          </camunda:formField>
          <camunda:formField id="creditScore" label="Credit Score" type="long">
            <camunda:properties><camunda:property id="readonly" value="true" /></camunda:properties>
          </camunda:formField>
          <camunda:formField id="creditworthy" label="Creditworthy" type="boolean">
            <camunda:properties><camunda:property id="readonly" value="true" /></camunda:properties>
          </camunda:formField>
          <camunda:formField id="leaseAmount" label="Lease Amount" type="long">
            <camunda:properties><camunda:property id="readonly" value="true" /></camunda:properties>
          </camunda:formField>
          <camunda:formField id="leaseTermMonths" label="Lease Term (months)" type="long">
