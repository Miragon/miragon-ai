{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "bundler",
    // widget-registry.test.ts pulls the module widget bundles (tsx) into this
    // program via src/ui/widget-registry.ts.
    "jsx": "react-jsx",
    "noEmit": true,
    "composite": false,
    "rootDir": "."
  },
  "include": ["src", "test", "test-host"],
  "exclude": ["src/ui"]
}
