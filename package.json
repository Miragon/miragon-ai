{
  "name": "miragon-ai",
  "version": "0.2.1",
  "private": true,
  "packageManager": "pnpm@10.32.1",
  "engines": {
    "node": ">=22"
  },
  "type": "module",
  "scripts": {
    "generate": "turbo run generate",
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky",
    "dev": "dotenv -e .env -- pnpm --filter @miragon-ai/mcp-server-camunda7 dev",
    "docs:dev": "pnpm --filter @miragon-ai/docs dev",
    "docs:build": "pnpm --filter @miragon-ai/docs build",
    "docs:preview": "pnpm --filter @miragon-ai/docs preview"
  },
  "devDependencies": {
    "@eslint/js": "9.39.4",
    "@types/node": "22.19.15",
    "@vitest/coverage-v8": "4.1.4",
    "dotenv-cli": "11.0.0",
    "eslint": "9.39.4",
    "eslint-plugin-react-hooks": "5.2.0",
    "husky": "9.1.7",
    "lint-staged": "15.5.2",
    "prettier": "3.8.2",
    "prettier-plugin-tailwindcss": "0.6.14",
    "turbo": "2.8.17",
    "typescript": "5.9.3",
    "typescript-eslint": "8.58.2",
    "vitest": "4.1.4"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml,css}": [
      "prettier --write"
    ]
  }
}
