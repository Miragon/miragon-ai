{
  "uid": "process-analytics",
  "title": "Process Analytics",
  "tags": ["camunda", "process", "analytics"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "engine_id",
        "label": "Engine",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "query": "label_values(camunda_process_instance_started_total, engine_id)",
        "includeAll": true,
        "multi": true,
        "current": { "text": "All", "value": "$__all" }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "row",
      "title": "Process health",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Throughput — instances started (per min)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 1 },
      "fieldConfig": {
        "defaults": { "unit": "opm", "custom": { "drawStyle": "line", "fillOpacity": 10 } },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (process_definition_key) (rate(camunda_process_instance_started_total{engine_id=~\"$engine_id\"}[5m])) * 60",
          "legendFormat": "{{process_definition_key}}"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Process duration p95 (s)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 1 },
      "fieldConfig": {
        "defaults": { "unit": "s", "custom": { "drawStyle": "line", "fillOpacity": 10 } },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.95, sum by (process_definition_key, le) (rate(camunda_process_instance_duration_seconds_bucket{engine_id=~\"$engine_id\"}[$__rate_interval])))",
          "legendFormat": "{{process_definition_key}}"
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Started vs. ended (per min)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 9 },
      "fieldConfig": {
        "defaults": { "unit": "opm", "custom": { "drawStyle": "line", "fillOpacity": 10 } },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum (rate(camunda_process_instance_started_total{engine_id=~\"$engine_id\"}[5m])) * 60",
          "legendFormat": "started"
        },
        {
          "refId": "B",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum (rate(camunda_process_instance_ended_total{engine_id=~\"$engine_id\"}[5m])) * 60",
          "legendFormat": "ended"
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Incident rate by type (per min)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 9 },
      "fieldConfig": {
        "defaults": { "unit": "opm", "custom": { "drawStyle": "bars", "fillOpacity": 40 } },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (incident_type) (rate(camunda_incident_created_total{engine_id=~\"$engine_id\"}[5m])) * 60",
          "legendFormat": "{{incident_type}}"
        }
      ]
    },
    {
      "id": 6,
      "type": "row",
      "title": "Bottlenecks",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 17 }
    },
    {
      "id": 7,
      "type": "table",
      "title": "Activity bottleneck — p95 duration (s)",
      "description": "The heatmap/bottleneck signal, straight from metrics: per-activity p95 over the dashboard range. No event store required.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 18 },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "options": { "sortBy": [{ "displayName": "Value", "desc": true }] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "format": "table",
          "instant": true,
          "expr": "histogram_quantile(0.95, sum by (process_definition_key, activity_id, activity_type, le) (increase(camunda_activity_duration_seconds_bucket{engine_id=~\"$engine_id\"}[$__range])))"
        }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": { "excludeByName": { "Time": true }, "renameByName": { "Value": "p95 (s)" } }
        }
      ]
    },
    {
      "id": 8,
      "type": "table",
      "title": "User task cycle time — p95 (s)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 18 },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "options": { "sortBy": [{ "displayName": "Value", "desc": true }] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "format": "table",
          "instant": true,
          "expr": "histogram_quantile(0.95, sum by (process_definition_key, task_definition_key, le) (increase(camunda_usertask_duration_seconds_bucket{engine_id=~\"$engine_id\"}[$__range])))"
        }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": { "excludeByName": { "Time": true }, "renameByName": { "Value": "p95 (s)" } }
        }
      ]
    },
    {
      "id": 9,
      "type": "row",
      "title": "Live state (current)",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 27 }
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "Running instances (WIP)",
      "description": "Authoritative live work-in-progress per definition — what flow counters cannot show.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 6, "x": 0, "y": 28 },
      "fieldConfig": {
        "defaults": { "custom": { "drawStyle": "line", "fillOpacity": 20 } },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "camunda_process_instances_running{engine_id=~\"$engine_id\"}",
          "legendFormat": "{{process_definition_key}}"
        }
      ]
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "Open incidents",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 6, "x": 6, "y": 28 },
      "fieldConfig": {
        "defaults": { "custom": { "drawStyle": "line", "fillOpacity": 20 } },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (incident_type) (camunda_incidents_open{engine_id=~\"$engine_id\"})",
          "legendFormat": "{{incident_type}}"
        }
      ]
    },
    {
      "id": 12,
      "type": "timeseries",
      "title": "Job health",
      "description": "Executable backlog, dead jobs (retries exhausted), and future-due jobs.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 28 },
      "fieldConfig": {
        "defaults": { "custom": { "drawStyle": "line", "fillOpacity": 10 } },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(camunda_jobs_executable{engine_id=~\"$engine_id\"})",
          "legendFormat": "executable"
        },
        {
          "refId": "B",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(camunda_jobs_failed{engine_id=~\"$engine_id\"})",
          "legendFormat": "dead (no retries)"
        },
        {
          "refId": "C",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(camunda_jobs_due_future{engine_id=~\"$engine_id\"})",
          "legendFormat": "due future"
        }
      ]
    },
    {
      "id": 13,
      "type": "timeseries",
      "title": "Open user tasks",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 28 },
      "fieldConfig": {
        "defaults": { "custom": { "drawStyle": "line", "fillOpacity": 20 } },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (status) (camunda_usertasks_open{engine_id=~\"$engine_id\", status=~\"total|unassigned\"})",
          "legendFormat": "{{status}}"
        }
      ]
    }
  ]
}
