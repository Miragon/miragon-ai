{
  "name": "@miragon-ai/mcp-gateway",
  "version": "0.1.0",
  "private": true,
  "license": "UNLICENSED",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Miragon/miragon-ai.git",
    "directory": "apps/mcp-gateway"
  },
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "mcp-gateway": "dist/index.js"
  },
  "scripts": {
    "build:ui": "cross-env INPUT=mcp-app.html vite build",
    "build:server": "tsc",
    "build": "pnpm run build:ui && pnpm run build:server",
    "dev:ui": "cross-env INPUT=mcp-app.html vite build --watch",
    "dev": "pnpm run build:ui && mcp-use dev --port 8400 --no-open",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.ui.json && tsc -p tsconfig.test.json",
    "test": "vitest run",
    "lint": "eslint src test",
    "lint:fix": "eslint src test --fix",
    "start": "cross-env NODE_ENV=production node dist/index.js"
  },
  "dependencies": {
    "@miragon/mcp-toolkit-core": "0.6.1",
    "@miragon/mcp-toolkit-proxy-contract": "0.6.1",
    "@miragon-ai/client-cibseven": "workspace:*",
    "@miragon-ai/mcp-cibseven": "workspace:*",
    "@miragon-ai/mcp-analytics": "workspace:*",
    "mcp-use": "1.32.1",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@miragon/mcp-toolkit-ui": "0.6.1",
    "@tailwindcss/vite": "4.2.2",
    "@types/node": "22.19.15",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.1",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "cross-env": "10.1.0",
    "radix-ui": "1.4.3",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "tailwind-merge": "3.5.0",
    "tailwindcss": "4.2.2",
    "typescript": "5.9.3",
    "vite": "8.0.8",
    "vite-plugin-singlefile": "2.3.2",
    "vitest": "4.1.4"
  }
}
