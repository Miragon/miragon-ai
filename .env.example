# Camunda 7 / CIB Seven engine connection (read by server/src/setup.ts).
export CAMUNDA_BASE_URL=http://localhost:8080/engine-rest
export CAMUNDA_AUTH_TYPE=basic
export CAMUNDA_USERNAME=demo
export CAMUNDA_PASSWORD=demo

# ClickHouse history store (read by analytics module).
export CLICKHOUSE_URL=http://localhost:8123
export CLICKHOUSE_USERNAME=camunda
export CLICKHOUSE_PASSWORD=camunda123
export CLICKHOUSE_DATABASE=camunda_history

# Enrichment module — opt-in. Point at one of the local-runnable demo YAMLs
# under server/resources/enrichment-examples/. Both expect the WireMock
# container from docker/docker-compose.yml to be running on localhost:8088.
#
#   loanApproval-local.yaml  → pairs with the cibseven loanApproval seed
#                              (customerSegment / currency / channel)
#   acme-local.yaml          → generic Salesforce / ERP / Contracts shape
#
# Leave unset to disable enrichment entirely (no boot error).
export ENRICHMENT_CONFIG_PATH=$(pwd)/server/resources/enrichment-examples/miraveloLeasing-local.yaml

# Miravelo upstream — mock CRM/leasing for the showcase
#   Used by examples/miravelo-upstream + the host (via MCP_PROXIES below).
UPSTREAM_MIRAVELO_PORT=4002

# MCP_PROXIES — JSON array. Each entry registers an UpstreamProxyPlugin in the host.
#   `upstreamModules: true` opts the proxy into module discovery — the host
#   calls `get-module-manifest` at boot and registers the returned step + widget.
#   If you already have entries, append the miravelo entry into the array.
MCP_PROXIES=[{"name":"miravelo","label":"Miravelo","upstreamUrl":"http://localhost:4002/mcp","auth":{"mode":"none"},"upstreamModules":true}]