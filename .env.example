# Camunda 7 / CIB Seven engine connection (read by apps/mcp-gateway/src/setup.ts).
export CAMUNDA_BASE_URL=http://localhost:8410/engine-rest
export CAMUNDA_AUTH_TYPE=basic
export CAMUNDA_USERNAME=demo
export CAMUNDA_PASSWORD=demo
export CAMUNDA_ENGINES_JSON='[{"id":"prod-a","baseUrl":"http://localhost:8410/engine-rest"},{"id":"prod-b","baseUrl":"http://localhost:8411/engine-rest"}]'

# ClickHouse history store (read by analytics module).
export CLICKHOUSE_URL=http://localhost:8420
export CLICKHOUSE_USERNAME=camunda
export CLICKHOUSE_PASSWORD=camunda123
export CLICKHOUSE_DATABASE=camunda_history

# Miravelo upstream — mock CRM/leasing for the showcase
#   Used by examples/miravelo-upstream + the host (via MCP_PROXIES below).
UPSTREAM_MIRAVELO_PORT=4002

# MCP_PROXIES — JSON array. Each entry registers an UpstreamProxyPlugin in the host.
#   `upstreamModules: true` opts the proxy into module discovery — the host
#   calls `get-module-manifest` at boot and registers the returned step + widget.
#   If you already have entries, append the miravelo entry into the array.
MCP_PROXIES=[{"name":"miravelo","label":"Miravelo","upstreamUrl":"http://localhost:4002/mcp","auth":{"mode":"none"},"upstreamModules":true}]

# MCP_DASHBOARD_DIR — optional. When set, dashboards saved via `save-dashboard`
#   are persisted as <id>.json files under this directory and survive restarts.
#   Unset → the toolkit's in-memory store (fine for dev, lost on restart).
# MCP_DASHBOARD_DIR=./.dashboards

# Engine-health verdict thresholds — optional, per deployment. The engine
# overview turns "critical" at >= CRITICAL_INCIDENTS open incidents in total,
# or when a single failure cluster reaches >= CRITICAL_CLUSTER_SIZE incidents.
# Unset → defaults (50 / 25).
# CAMUNDA_HEALTH_CRITICAL_INCIDENTS=50
# CAMUNDA_HEALTH_CRITICAL_CLUSTER_SIZE=25
