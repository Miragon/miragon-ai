  <bpmn:error id="Error_BadCreditScore" name="Bad credit score" errorCode="BAD_CREDIT_SCORE" />
  <bpmn:error id="Error_UndeliverablePostalCode" name="Undeliverable postal code" errorCode="UNDELIVERABLE_POSTAL_CODE" />
  <bpmn:error id="Error_BlacklistHit" name="Blacklist hit" errorCode="BLACKLIST_HIT" />
  <bpmn:collaboration id="Collaboration_0ifnzux">
    <bpmn:participant id="Participant_0ilbgu1" name="Assess Customer credebility" processRef="assessCreditworthiness" />
  </bpmn:collaboration>
  <bpmn:process id="assessCreditworthiness" isExecutable="true" camunda:historyTimeToLive="P30D">
    <bpmn:startEvent id="StartEvent_CheckRequired" name="Check required">
      <bpmn:outgoing>Flow_1uz5ar2</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:sequenceFlow id="Flow_1uz5ar2" sourceRef="StartEvent_CheckRequired" targetRef="Activity_CheckCreditScore" />
    <bpmn:sequenceFlow id="Flow_1p6to0y" sourceRef="Activity_CheckCreditScore" targetRef="Activity_CheckPostalCode" />
    <bpmn:sequenceFlow id="Flow_0vo0xvf" sourceRef="Activity_CheckPostalCode" targetRef="Activity_CheckBlacklist" />
    <bpmn:sequenceFlow id="Flow_05l0gz3" sourceRef="Activity_CheckBlacklist" targetRef="Event_CustomerCreditworthy" />
    <bpmn:serviceTask id="Activity_CheckCreditScore" name="Check Credit Score" camunda:delegateExpression="${checkCreditScoreDelegate}">
      <bpmn:incoming>Flow_1uz5ar2</bpmn:incoming>
      <bpmn:outgoing>Flow_1p6to0y</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="Activity_CheckPostalCode" name="Check postal code area" camunda:delegateExpression="${checkPostalCodeDelegate}">
      <bpmn:incoming>Flow_1p6to0y</bpmn:incoming>
      <bpmn:outgoing>Flow_0vo0xvf</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="Activity_CheckBlacklist" name="Check blacklist" camunda:delegateExpression="${checkBlacklistDelegate}" camunda:asyncBefore="true">
      <bpmn:incoming>Flow_0vo0xvf</bpmn:incoming>
      <bpmn:outgoing>Flow_05l0gz3</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:boundaryEvent id="Event_BadCreditScoreCaught" name="bad credit score" attachedToRef="Activity_CheckCreditScore">
      <bpmn:outgoing>Flow_09ltnyj</bpmn:outgoing>
      <bpmn:errorEventDefinition id="ErrorEventDefinition_0xzkofp" errorRef="Error_BadCreditScore" />
    </bpmn:boundaryEvent>
    <bpmn:boundaryEvent id="Event_UndeliverableCaught" name="lives in an area we do not deliver to" attachedToRef="Activity_CheckPostalCode">
      <bpmn:outgoing>Flow_1qse5po</bpmn:outgoing>
      <bpmn:errorEventDefinition id="ErrorEventDefinition_04dffz0" errorRef="Error_UndeliverablePostalCode" />
    </bpmn:boundaryEvent>
    <bpmn:boundaryEvent id="Event_BlacklistHitCaught" name="We do not want to do business with said client" attachedToRef="Activity_CheckBlacklist">
      <bpmn:outgoing>Flow_1lfgbeh</bpmn:outgoing>
      <bpmn:errorEventDefinition id="ErrorEventDefinition_0qsblv5" errorRef="Error_BlacklistHit" />
    </bpmn:boundaryEvent>
    <bpmn:sequenceFlow id="Flow_1lfgbeh" sourceRef="Event_BlacklistHitCaught" targetRef="Event_RiskIdentified" />
    <bpmn:sequenceFlow id="Flow_1qse5po" sourceRef="Event_UndeliverableCaught" targetRef="Event_RiskIdentified" />
    <bpmn:sequenceFlow id="Flow_09ltnyj" sourceRef="Event_BadCreditScoreCaught" targetRef="Event_RiskIdentified" />
    <bpmn:endEvent id="Event_CustomerCreditworthy" name="Customer creditworthy">
      <bpmn:incoming>Flow_05l0gz3</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:endEvent id="Event_RiskIdentified" name="Risk identified">
      <bpmn:incoming>Flow_1lfgbeh</bpmn:incoming>
      <bpmn:incoming>Flow_1qse5po</bpmn:incoming>
      <bpmn:incoming>Flow_09ltnyj</bpmn:incoming>
    </bpmn:endEvent>
  </bpmn:process>
