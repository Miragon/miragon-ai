    </bpmn:startEvent>
    <bpmn:boundaryEvent id="Event_DecisionTimeout" name="after 2 hours" cancelActivity="false" attachedToRef="Activity_DecideOnApplication">
      <bpmn:outgoing>Flow_1py2c7t</bpmn:outgoing>
      <bpmn:timerEventDefinition id="TimerEventDefinition_0eztp8f">
        <bpmn:timeDuration xsi:type="bpmn:tFormalExpression" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">PT2H</bpmn:timeDuration>
      </bpmn:timerEventDefinition>
    </bpmn:boundaryEvent>
    <bpmn:sequenceFlow id="Flow_0vvp9qn" sourceRef="Activity_AssessCreditworthiness" targetRef="Gateway_Creditworthy" />
    <bpmn:sequenceFlow id="Flow_1oiz1dg" name="yes" sourceRef="Gateway_Creditworthy" targetRef="Activity_DeliverPolicy">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">${creditworthy == true}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_18i81hz" name="risk identified" sourceRef="Gateway_Creditworthy" targetRef="Activity_DecideOnApplication" />
    <bpmn:sequenceFlow id="Flow_1py2c7t" sourceRef="Event_DecisionTimeout" targetRef="Activity_AccelerateDecision" />
    <bpmn:sequenceFlow id="Flow_0r2ryqa" sourceRef="Activity_AccelerateDecision" targetRef="Event_DecisionAccelerated" />
    <bpmn:sequenceFlow id="Flow_07uig79" sourceRef="Activity_ResolveCustomer" targetRef="Activity_AssessCreditworthiness" />
    <bpmn:sequenceFlow id="Flow_0ax166r" sourceRef="Activity_DecideOnApplication" targetRef="Gateway_Decision" />
    <bpmn:sequenceFlow id="Flow_0vnxels" name="positive" sourceRef="Gateway_Decision" targetRef="Activity_DeliverPolicy">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">${decision == "positive"}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_1yvzx67" name="negative" sourceRef="Gateway_Decision" targetRef="Activity_RejectPolicy" />
    <bpmn:sequenceFlow id="Flow_1cy38un" sourceRef="Activity_SendPolicy" targetRef="Event_PolicyIssued" />
    <bpmn:sequenceFlow id="Flow_0v4qedl" sourceRef="Activity_DeliverPolicy" targetRef="Activity_SendPolicy" />
    <bpmn:sequenceFlow id="Flow_1cc5ecu" sourceRef="Activity_RejectPolicy" targetRef="Activity_SendRejection" />
    <bpmn:sequenceFlow id="Flow_0m7ynmt" sourceRef="Activity_SendRejection" targetRef="Event_PolicyRejected" />
    <bpmn:sequenceFlow id="Flow_1fnfazk" sourceRef="StartEvent_LeasingInquiry" targetRef="Activity_ResolveCustomer" />
  </bpmn:process>
