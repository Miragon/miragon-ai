{
  "name": "@miragon-ai/miravelo-upstream",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "description": "Mock CRM/leasing upstream for the Miravelo showcase. Exposes a get-module-manifest with a declarative step + a remote-hosted leasing application widget. Wired into the host via MCP_PROXIES (upstreamModules: true).",
  "scripts": {
    "build:widget": "vite build --config widget/vite.config.ts",
    "dev": "pnpm run build:widget && tsx --env-file-if-exists=.env server.ts",
    "start": "pnpm run dev",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@miragon/mcp-toolkit-proxy-contract": "workspace:*",
    "mcp-use": "1.23.1",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@types/node": "22.19.15",
    "@types/react": "19.2.14",
    "@vitejs/plugin-react": "6.0.1",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "tsx": "4.20.6",
    "typescript": "5.9.3",
    "vite": "8.0.8"
  }
}
