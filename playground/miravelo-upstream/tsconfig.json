{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "rootDir": ".",
    "lib": ["ES2022", "DOM"],
    "types": ["node"]
  },
  "include": ["server.ts", "data.ts", "shared/**/*.ts", "widget/**/*.ts", "widget/**/*.tsx"]
}
