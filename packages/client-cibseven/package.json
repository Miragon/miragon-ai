{
  "name": "@miragon-ai/client-cibseven",
  "version": "0.2.1",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Miragon/miragon-ai.git",
    "directory": "packages/client-cibseven"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "restricted"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./sdk": {
      "types": "./dist/generated/sdk.gen.d.ts",
      "import": "./dist/generated/sdk.gen.js"
    },
    "./types": {
      "types": "./dist/generated/types.gen.d.ts",
      "import": "./dist/generated/types.gen.js"
    },
    "./schemas": {
      "types": "./dist/schemas/index.d.ts",
      "import": "./dist/schemas/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "generate": "openapi-ts",
    "spec:refresh": "sh ./scripts/refresh-spec.sh"
  },
  "dependencies": {
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@hey-api/openapi-ts": "0.94.5",
    "typescript": "5.9.3",
    "vitest": "4.1.4"
  }
}
