  <bpmn:collaboration id="Collaboration_1wc5tgg">
    <bpmn:participant id="Participant_1kl582i" name="Miravelo - Bike Leasing" processRef="miraveloLeasing" />
  </bpmn:collaboration>
  <bpmn:process id="miraveloLeasing" isExecutable="true" camunda:historyTimeToLive="P30D">
    <bpmn:exclusiveGateway id="Gateway_Creditworthy" name="Customer creditworthy?" default="Flow_18i81hz">
      <bpmn:incoming>Flow_0vvp9qn</bpmn:incoming>
      <bpmn:outgoing>Flow_1oiz1dg</bpmn:outgoing>
      <bpmn:outgoing>Flow_18i81hz</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:userTask id="Activity_AccelerateDecision" name="Accelerate decision making">
      <bpmn:extensionElements>
        <camunda:formData>
          <camunda:formField id="customerId" label="Customer ID" type="string">
            <camunda:properties><camunda:property id="readonly" value="true" /></camunda:properties>
          </camunda:formField>
          <camunda:formField id="creditScore" label="Credit Score" type="long">
            <camunda:properties><camunda:property id="readonly" value="true" /></camunda:properties>
          </camunda:formField>
          <camunda:formField id="creditworthy" label="Creditworthy" type="boolean">
            <camunda:properties><camunda:property id="readonly" value="true" /></camunda:properties>
          </camunda:formField>
          <camunda:formField id="leaseAmount" label="Lease Amount" type="long">
            <camunda:properties><camunda:property id="readonly" value="true" /></camunda:properties>
          </camunda:formField>
          <camunda:formField id="leaseTermMonths" label="Lease Term (months)" type="long">
            <camunda:properties><camunda:property id="readonly" value="true" /></camunda:properties>
          </camunda:formField>
          <camunda:formField id="bikeModel" label="Bike Model" type="string">
